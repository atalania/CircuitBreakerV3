# Copy to .env.local and fill in your key (never commit .env.local)
# Restart `npm run dev` or `npm run preview` after changes.

OPENAI_API_KEY=

# Optional — e.g. gpt-4o-mini, gpt-4o, gpt-4-turbo
# OPENAI_MODEL=gpt-4o-mini

# Optional — model string sent from the browser to the AI proxy (portal or local middleware)
# VITE_OPENAI_MODEL=gpt-4o-mini

# Optional — override AI proxy URL/path (default /api/ai/openai). Use when the portal uses a new route or absolute URL.
# VITE_AI_PROXY_URL=https://your-portal.example.com/api/ai/openai

# When developing against the web portal: portal on localhost:3000, proxy /api to it (no local OpenAI key in this repo)
# PORTAL_DEV=1

# Wiki assistant bridge: events post when embedded in an iframe (parent !== self).
# Set =1 to force events when not iframe-wrapped (e.g. Vitest); =0 to disable on embed.
# VITE_PORTAL_ASSISTANT=1
# Override slug if it differs from data/game.json "game-id" (must match src/data/games.ts on the wiki).
# VITE_ASSISTANT_GAME_ID=circuit-breaker
# Target concept strings emitted per campaign level live in js/app/portalGameContext.js (`getPortalTargetConcept`);
# they must align with STEM assistant registrations on the portal side when routing hints.
